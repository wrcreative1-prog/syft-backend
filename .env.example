# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service.
# Local: postgresql://postgres:password@localhost:5432/syft
DATABASE_URL=postgresql://user:password@host:5432/syft

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ── Apple Sign In ─────────────────────────────────────────────────────────────
# Your app's bundle ID (e.g. com.yourname.syft)
APPLE_CLIENT_ID=com.yourname.syft

# ── Google Sign In ────────────────────────────────────────────────────────────
# From your Google Cloud Console → OAuth 2.0 Client IDs → iOS client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave blank to allow all (dev only).
# ALLOWED_ORIGINS=https://yourdomain.com,capacitor://localhost
